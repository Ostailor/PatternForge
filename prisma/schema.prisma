generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Difficulty {
  Easy
  Medium
  Hard
}

enum SolvedStatus {
  Solved
  PartiallySolved
  NotSolved
}

enum ReviewItemType {
  Flashcard
  Mistake
}

enum ReviewRating {
  Again
  Hard
  Good
  Easy
}

enum BattleType {
  PatternBoss
  MixedBattle
  ReviewGauntlet
}

enum BattleStatus {
  Active
  Completed
  Abandoned
}

enum BattleResult {
  Victory
  PartialVictory
  Defeat
}

enum RoundType {
  Warmup
  MainForge
  PatternTwist
  MixedReview
  BossProblem
}

enum QuestStatus {
  Active
  Completed
  Expired
}

enum GameEventType {
  AttemptCompleted
  ReviewCompleted
  BattleCompleted
  InterviewStarted
  InterviewCompleted
  InterviewStrongResult
  InterviewImprovement
  QuestCompleted
  AchievementEarned
  ContrastDrillCompleted
}

enum RecommendationType {
  DueReview
  FocusPattern
  ContrastDrill
  RetryProblem
  BossBattle
  ReviewGauntlet
  AIReviewFollowUp
  LearningPlanStep
  MockInterview
  FocusedInterview
  WeaknessRepairInterview
  DailyForge
  DebugDrill
  TestingPractice
  ImplementationPractice
}

enum RecommendationStatus {
  Active
  Accepted
  Completed
  Dismissed
  Expired
}

enum InsightType {
  WeakPattern
  StrongPattern
  ConfusingPattern
  RetentionRisk
  ReadyForBoss
  Plateau
  NeedsReview
  NeedsImplementationPractice
}

enum InsightSeverity {
  Low
  Medium
  High
}

enum LearningPlanStatus {
  Active
  Completed
  Paused
  Abandoned
}

enum LearningPlanStepStatus {
  Pending
  Active
  Completed
  Skipped
}

enum RecommendationFeedbackType {
  Accepted
  Dismissed
  TooEasy
  TooHard
  NotRelevant
  Helpful
}

enum InterviewType {
  SingleProblem
  FocusedPattern
  MixedInterview
  WeaknessRepair
}

enum InterviewStatus {
  Active
  Completed
  Abandoned
}

enum InterviewRoundStatus {
  Pending
  Active
  Completed
  Skipped
}

enum InterviewResult {
  StrongHire
  Hire
  LeanHire
  LeanNoHire
  NoHire
}

enum InterviewMessageRole {
  User
  Interviewer
  System
}

enum InterviewPhase {
  Setup
  ClarifyingQuestions
  PatternHypothesis
  Approach
  Implementation
  Testing
  Complexity
  Feedback
}

enum RubricCategory {
  Communication
  PatternRecognition
  ProblemSolving
  Implementation
  Testing
  Complexity
  TimeManagement
}

enum CodeLanguage {
  Python
}

enum CodeSubmissionStatus {
  Draft
  Submitted
  Reviewed
}

enum CodeRunType {
  CustomTests
  SmokeTest
  FreeRun
}

enum CodeRunStatus {
  Queued
  Running
  Succeeded
  Failed
  TimedOut
  RuntimeError
  ValidationError
}

enum TestCaseSource {
  User
  PatternForge
}

model UserProfile {
  id                     String                   @id @default(cuid())
  authUserId             String                   @unique
  displayName            String
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  attempts               Attempt[]
  aiReviews              AIReview[]
  mistakes               Mistake[]
  flashcards             Flashcard[]
  reviewLogs             ReviewLog[]
  battles                Battle[]
  quests                 Quest[]
  userAchievements       UserAchievement[]
  gameEvents             GameEvent[]
  recommendations        Recommendation[]
  patternInsights        PatternInsight[]
  patternConfusions      PatternConfusion[]
  learningPlans          LearningPlan[]
  recommendationFeedback RecommendationFeedback[]
  interviewSessions      InterviewSession[]
  codeSubmissions        CodeSubmission[]
  codeRuns               CodeRun[]
  testCases              TestCase[]
  debugInsights          DebugInsight[]
}

model Pattern {
  id                       String             @id
  name                     String
  category                 String
  description              String             @db.Text
  recognitionClues         String[]           @default([])
  templateSummary          String             @db.Text
  commonMistakes           String[]           @default([])
  levelOrder               Int
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  problemPatterns          ProblemPattern[]
  selectedAttempts         Attempt[]          @relation("SelectedPattern")
  correctAttempts          Attempt[]          @relation("CorrectPattern")
  aiReviews                AIReview[]
  mistakes                 Mistake[]
  flashcards               Flashcard[]
  targetBattles            Battle[]
  expectedRounds           BattleRound[]
  targetRecommendations    Recommendation[]   @relation("RecommendationTargetPattern")
  secondaryRecommendations Recommendation[]   @relation("RecommendationSecondaryPattern")
  patternInsights          PatternInsight[]
  selectedConfusions       PatternConfusion[] @relation("SelectedConfusionPattern")
  correctConfusions        PatternConfusion[] @relation("CorrectConfusionPattern")
  learningPlanSteps        LearningPlanStep[]
  targetInterviewSessions  InterviewSession[]
  selectedInterviewRounds  InterviewRound[]   @relation("InterviewRoundSelectedPattern")
  correctInterviewRounds   InterviewRound[]   @relation("InterviewRoundCorrectPattern")

  @@index([levelOrder])
}

model Problem {
  id                String                @id
  title             String
  url               String                @unique
  difficulty        Difficulty
  estimatedMinutes  Int
  recognitionClues  String[]              @default([])
  commonMistakes    String[]              @default([])
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  problemPatterns   ProblemPattern[]
  attempts          Attempt[]
  aiReviews         AIReview[]
  mistakes          Mistake[]
  battleRounds      BattleRound[]
  recommendations   Recommendation[]
  learningPlanSteps LearningPlanStep[]
  interviewRounds   InterviewRound[]
  runnerConfigs     ProblemRunnerConfig[]
  codeSubmissions   CodeSubmission[]
  testCases         TestCase[]
}

model ProblemPattern {
  id        String  @id @default(cuid())
  problemId String
  patternId String
  isPrimary Boolean @default(false)
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  pattern   Pattern @relation(fields: [patternId], references: [id], onDelete: Restrict)

  @@unique([problemId, patternId])
  @@index([problemId])
  @@index([patternId])
  @@index([problemId, isPrimary])
}

model ProblemRunnerConfig {
  id              String       @id @default(cuid())
  problemId       String
  language        CodeLanguage
  functionName    String
  inputSchema     Json
  outputSchema    Json
  harnessTemplate String       @db.Text
  isEnabled       Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  problem         Problem      @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
  @@index([language])
  @@index([createdAt])
}

model Attempt {
  id                String           @id @default(cuid())
  userProfileId     String
  problemId         String
  selectedPatternId String
  correctPatternId  String
  wasPatternCorrect Boolean
  solvedStatus      SolvedStatus
  timeSpentMinutes  Int
  confidence        Int
  reflection        String           @db.Text
  createdAt         DateTime         @default(now())
  userProfile       UserProfile      @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  problem           Problem          @relation(fields: [problemId], references: [id], onDelete: Restrict)
  selectedPattern   Pattern          @relation("SelectedPattern", fields: [selectedPatternId], references: [id], onDelete: Restrict)
  correctPattern    Pattern          @relation("CorrectPattern", fields: [correctPatternId], references: [id], onDelete: Restrict)
  aiReviews         AIReview[]
  mistakes          Mistake[]
  flashcards        Flashcard[]
  battleRounds      BattleRound[]
  interviewRounds   InterviewRound[]
  codeSubmissions   CodeSubmission[]
  debugInsights     DebugInsight[]

  @@index([userProfileId])
  @@index([problemId])
  @@index([selectedPatternId])
  @@index([correctPatternId])
  @@index([userProfileId, problemId])
  @@index([userProfileId, createdAt])
}

model AIReview {
  id                  String           @id @default(cuid())
  userProfileId       String
  attemptId           String
  problemId           String
  patternId           String
  patternScore        Int
  implementationScore Int
  complexityScore     Int
  explanationScore    Int
  feedbackSummary     String           @db.Text
  strengths           String[]         @default([])
  weaknesses          String[]         @default([])
  complexityFeedback  String           @db.Text
  suggestedNextStep   String           @db.Text
  createdAt           DateTime         @default(now())
  userProfile         UserProfile      @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  attempt             Attempt          @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  problem             Problem          @relation(fields: [problemId], references: [id], onDelete: Restrict)
  pattern             Pattern          @relation(fields: [patternId], references: [id], onDelete: Restrict)
  interviewRounds     InterviewRound[]

  @@index([userProfileId])
  @@index([attemptId])
  @@index([problemId])
  @@index([patternId])
  @@index([createdAt])
}

model Mistake {
  id             String      @id @default(cuid())
  userProfileId  String
  attemptId      String
  problemId      String
  patternId      String
  mistakeType    String
  description    String      @db.Text
  correction     String      @db.Text
  reviewDueAt    DateTime
  lastReviewedAt DateTime?
  intervalDays   Int         @default(0)
  easeFactor     Float       @default(2.5)
  repetitions    Int         @default(0)
  lapses         Int         @default(0)
  status         String      @default("active")
  createdAt      DateTime    @default(now())
  userProfile    UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  attempt        Attempt     @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  problem        Problem     @relation(fields: [problemId], references: [id], onDelete: Restrict)
  pattern        Pattern     @relation(fields: [patternId], references: [id], onDelete: Restrict)
  reviewLogs     ReviewLog[]

  @@index([userProfileId])
  @@index([attemptId])
  @@index([problemId])
  @@index([patternId])
  @@index([reviewDueAt])
  @@index([createdAt])
}

model Flashcard {
  id              String      @id @default(cuid())
  userProfileId   String
  sourceAttemptId String?
  patternId       String
  front           String      @db.Text
  back            String      @db.Text
  reviewDueAt     DateTime
  lastReviewedAt  DateTime?
  intervalDays    Int         @default(0)
  easeFactor      Float       @default(2.5)
  repetitions     Int         @default(0)
  lapses          Int         @default(0)
  status          String      @default("active")
  createdAt       DateTime    @default(now())
  userProfile     UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  sourceAttempt   Attempt?    @relation(fields: [sourceAttemptId], references: [id], onDelete: SetNull)
  pattern         Pattern     @relation(fields: [patternId], references: [id], onDelete: Restrict)
  reviewLogs      ReviewLog[]

  @@index([userProfileId])
  @@index([sourceAttemptId])
  @@index([patternId])
  @@index([reviewDueAt])
  @@index([createdAt])
}

model ReviewLog {
  id                   String         @id @default(cuid())
  userProfileId        String
  flashcardId          String?
  mistakeId            String?
  itemType             ReviewItemType
  rating               ReviewRating
  previousIntervalDays Int
  nextIntervalDays     Int
  reviewedAt           DateTime       @default(now())
  userProfile          UserProfile    @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  flashcard            Flashcard?     @relation(fields: [flashcardId], references: [id], onDelete: SetNull)
  mistake              Mistake?       @relation(fields: [mistakeId], references: [id], onDelete: SetNull)

  @@index([userProfileId])
  @@index([reviewedAt])
  @@index([flashcardId])
  @@index([mistakeId])
}

model Battle {
  id              String        @id @default(cuid())
  userProfileId   String
  battleType      BattleType
  title           String
  targetPatternId String?
  status          BattleStatus  @default(Active)
  startedAt       DateTime      @default(now())
  completedAt     DateTime?
  totalRounds     Int
  xpEarned        Int           @default(0)
  result          BattleResult?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  userProfile     UserProfile   @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  targetPattern   Pattern?      @relation(fields: [targetPatternId], references: [id], onDelete: Restrict)
  rounds          BattleRound[]

  @@index([userProfileId])
  @@index([targetPatternId])
  @@index([status])
  @@index([createdAt])
}

model BattleRound {
  id                String           @id @default(cuid())
  battleId          String
  problemId         String
  roundNumber       Int
  roundType         RoundType
  expectedPatternId String
  attemptId         String?
  completedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  battle            Battle           @relation(fields: [battleId], references: [id], onDelete: Cascade)
  problem           Problem          @relation(fields: [problemId], references: [id], onDelete: Restrict)
  expectedPattern   Pattern          @relation(fields: [expectedPatternId], references: [id], onDelete: Restrict)
  attempt           Attempt?         @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  codeSubmissions   CodeSubmission[]

  @@unique([battleId, roundNumber])
  @@index([battleId])
  @@index([problemId])
  @@index([expectedPatternId])
  @@index([attemptId])
  @@index([createdAt])
}

model Quest {
  id            String      @id @default(cuid())
  userProfileId String
  questType     String
  title         String
  description   String      @db.Text
  targetCount   Int
  currentCount  Int         @default(0)
  xpReward      Int         @default(0)
  status        QuestStatus @default(Active)
  date          DateTime
  completedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@index([userProfileId])
  @@index([status])
  @@index([date])
  @@index([createdAt])
}

model Achievement {
  id               String            @id @default(cuid())
  key              String            @unique
  name             String
  description      String            @db.Text
  icon             String
  xpReward         Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  userAchievements UserAchievement[]

  @@index([createdAt])
}

model UserAchievement {
  id            String      @id @default(cuid())
  userProfileId String
  achievementId String
  earnedAt      DateTime    @default(now())
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userProfileId, achievementId])
  @@index([userProfileId])
  @@index([achievementId])
  @@index([earnedAt])
}

model GameEvent {
  id            String        @id @default(cuid())
  userProfileId String
  eventType     GameEventType
  xpAmount      Int
  description   String        @db.Text
  metadata      Json          @default("{}")
  eventKey      String        @unique
  createdAt     DateTime      @default(now())
  userProfile   UserProfile   @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@index([userProfileId])
  @@index([eventType])
  @@index([createdAt])
}

model Recommendation {
  id                 String                   @id @default(cuid())
  userProfileId      String
  recommendationType RecommendationType
  priority           Int
  status             RecommendationStatus     @default(Active)
  title              String
  reason             String                   @db.Text
  targetPatternId    String?
  secondaryPatternId String?
  problemId          String?
  battleType         BattleType?
  metadata           Json                     @default("{}")
  expiresAt          DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  userProfile        UserProfile              @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  targetPattern      Pattern?                 @relation("RecommendationTargetPattern", fields: [targetPatternId], references: [id], onDelete: Restrict)
  secondaryPattern   Pattern?                 @relation("RecommendationSecondaryPattern", fields: [secondaryPatternId], references: [id], onDelete: Restrict)
  problem            Problem?                 @relation(fields: [problemId], references: [id], onDelete: Restrict)
  feedback           RecommendationFeedback[]

  @@index([userProfileId])
  @@index([recommendationType])
  @@index([status])
  @@index([priority])
  @@index([targetPatternId])
  @@index([secondaryPatternId])
  @@index([problemId])
  @@index([createdAt])
}

model PatternInsight {
  id            String          @id @default(cuid())
  userProfileId String
  patternId     String
  insightType   InsightType
  severity      InsightSeverity
  summary       String          @db.Text
  evidence      Json            @default("{}")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  userProfile   UserProfile     @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  pattern       Pattern         @relation(fields: [patternId], references: [id], onDelete: Restrict)

  @@index([userProfileId])
  @@index([patternId])
  @@index([insightType])
  @@index([severity])
  @@index([createdAt])
}

model PatternConfusion {
  id                String      @id @default(cuid())
  userProfileId     String
  selectedPatternId String
  correctPatternId  String
  count             Int         @default(0)
  lastSeenAt        DateTime
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  userProfile       UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  selectedPattern   Pattern     @relation("SelectedConfusionPattern", fields: [selectedPatternId], references: [id], onDelete: Restrict)
  correctPattern    Pattern     @relation("CorrectConfusionPattern", fields: [correctPatternId], references: [id], onDelete: Restrict)

  @@unique([userProfileId, selectedPatternId, correctPatternId])
  @@index([userProfileId])
  @@index([selectedPatternId])
  @@index([correctPatternId])
  @@index([createdAt])
}

model LearningPlan {
  id            String             @id @default(cuid())
  userProfileId String
  title         String
  goal          String             @db.Text
  status        LearningPlanStatus @default(Active)
  startDate     DateTime
  endDate       DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  userProfile   UserProfile        @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  steps         LearningPlanStep[]

  @@index([userProfileId])
  @@index([status])
  @@index([startDate])
  @@index([createdAt])
}

model LearningPlanStep {
  id              String                 @id @default(cuid())
  learningPlanId  String
  dayIndex        Int
  stepType        String
  title           String
  targetPatternId String?
  problemId       String?
  targetCount     Int?
  status          LearningPlanStepStatus @default(Pending)
  dueDate         DateTime
  completedAt     DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  learningPlan    LearningPlan           @relation(fields: [learningPlanId], references: [id], onDelete: Cascade)
  targetPattern   Pattern?               @relation(fields: [targetPatternId], references: [id], onDelete: Restrict)
  problem         Problem?               @relation(fields: [problemId], references: [id], onDelete: Restrict)

  @@index([learningPlanId])
  @@index([targetPatternId])
  @@index([problemId])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
}

model RecommendationFeedback {
  id               String                     @id @default(cuid())
  userProfileId    String
  recommendationId String
  feedbackType     RecommendationFeedbackType
  note             String?                    @db.Text
  createdAt        DateTime                   @default(now())
  userProfile      UserProfile                @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  recommendation   Recommendation             @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@index([userProfileId])
  @@index([recommendationId])
  @@index([feedbackType])
  @@index([createdAt])
}

model InterviewSession {
  id                      String                 @id @default(cuid())
  userProfileId           String
  interviewType           InterviewType
  status                  InterviewStatus        @default(Active)
  title                   String
  targetPatternId         String?
  difficultyTarget        Difficulty?
  durationMinutes         Int
  startedAt               DateTime               @default(now())
  completedAt             DateTime?
  overallScore            Int?
  communicationScore      Int?
  patternRecognitionScore Int?
  problemSolvingScore     Int?
  implementationScore     Int?
  testingScore            Int?
  complexityScore         Int?
  timeManagementScore     Int?
  result                  InterviewResult?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  userProfile             UserProfile            @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  targetPattern           Pattern?               @relation(fields: [targetPatternId], references: [id], onDelete: Restrict)
  rounds                  InterviewRound[]
  messages                InterviewMessage[]
  feedbackRecords         InterviewFeedback[]
  rubricScores            InterviewRubricScore[]

  @@index([userProfileId])
  @@index([targetPatternId])
  @@index([status])
  @@index([startedAt])
  @@index([completedAt])
  @@index([createdAt])
}

model InterviewRound {
  id                 String               @id @default(cuid())
  interviewSessionId String
  problemId          String
  roundNumber        Int
  status             InterviewRoundStatus @default(Pending)
  startedAt          DateTime             @default(now())
  completedAt        DateTime?
  selectedPatternId  String?
  correctPatternId   String
  patternExplanation String?              @db.Text
  approachText       String?              @db.Text
  codeText           String?              @db.Text
  testCasesText      String?              @db.Text
  complexityText     String?              @db.Text
  attemptId          String?
  aiReviewId         String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  interviewSession   InterviewSession     @relation(fields: [interviewSessionId], references: [id], onDelete: Cascade)
  problem            Problem              @relation(fields: [problemId], references: [id], onDelete: Restrict)
  selectedPattern    Pattern?             @relation("InterviewRoundSelectedPattern", fields: [selectedPatternId], references: [id], onDelete: Restrict)
  correctPattern     Pattern              @relation("InterviewRoundCorrectPattern", fields: [correctPatternId], references: [id], onDelete: Restrict)
  attempt            Attempt?             @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  aiReview           AIReview?            @relation(fields: [aiReviewId], references: [id], onDelete: SetNull)
  messages           InterviewMessage[]
  feedbackRecords    InterviewFeedback[]
  codeSubmissions    CodeSubmission[]
  debugInsights      DebugInsight[]

  @@unique([interviewSessionId, roundNumber])
  @@index([interviewSessionId])
  @@index([problemId])
  @@index([status])
  @@index([startedAt])
  @@index([completedAt])
  @@index([createdAt])
  @@index([selectedPatternId])
  @@index([correctPatternId])
  @@index([attemptId])
  @@index([aiReviewId])
}

model CodeSubmission {
  id               String               @id @default(cuid())
  userProfileId    String
  problemId        String
  attemptId        String?
  interviewRoundId String?
  battleRoundId    String?
  language         CodeLanguage
  code             String               @db.Text
  status           CodeSubmissionStatus @default(Draft)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  userProfile      UserProfile          @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  problem          Problem              @relation(fields: [problemId], references: [id], onDelete: Restrict)
  attempt          Attempt?             @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  interviewRound   InterviewRound?      @relation(fields: [interviewRoundId], references: [id], onDelete: SetNull)
  battleRound      BattleRound?         @relation(fields: [battleRoundId], references: [id], onDelete: SetNull)
  codeRuns         CodeRun[]

  @@index([userProfileId])
  @@index([problemId])
  @@index([attemptId])
  @@index([interviewRoundId])
  @@index([battleRoundId])
  @@index([status])
  @@index([language])
  @@index([createdAt])
}

model CodeRun {
  id               String         @id @default(cuid())
  userProfileId    String
  codeSubmissionId String
  runType          CodeRunType
  status           CodeRunStatus  @default(Queued)
  stdout           String         @default("") @db.Text
  stderr           String         @default("") @db.Text
  compileOutput    String?        @db.Text
  errorMessage     String?        @db.Text
  runtimeMs        Int?
  memoryKb         Int?
  createdAt        DateTime       @default(now())
  userProfile      UserProfile    @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  codeSubmission   CodeSubmission @relation(fields: [codeSubmissionId], references: [id], onDelete: Cascade)
  testResults      TestResult[]
  debugInsights    DebugInsight[]

  @@index([userProfileId])
  @@index([codeSubmissionId])
  @@index([status])
  @@index([createdAt])
}

model TestCase {
  id                 String         @id @default(cuid())
  userProfileId      String?
  problemId          String
  source             TestCaseSource
  name               String
  inputJson          Json
  expectedOutputJson Json
  isPublic           Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  userProfile        UserProfile?   @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  problem            Problem        @relation(fields: [problemId], references: [id], onDelete: Cascade)
  testResults        TestResult[]

  @@index([userProfileId])
  @@index([problemId])
  @@index([source])
  @@index([createdAt])
}

model TestResult {
  id                 String    @id @default(cuid())
  codeRunId          String
  testCaseId         String?
  name               String
  inputJson          Json
  expectedOutputJson Json
  actualOutputJson   Json?
  passed             Boolean
  stdout             String?   @db.Text
  stderr             String?   @db.Text
  errorMessage       String?   @db.Text
  runtimeMs          Int?
  createdAt          DateTime  @default(now())
  codeRun            CodeRun   @relation(fields: [codeRunId], references: [id], onDelete: Cascade)
  testCase           TestCase? @relation(fields: [testCaseId], references: [id], onDelete: SetNull)

  @@index([codeRunId])
  @@index([testCaseId])
  @@index([createdAt])
}

model DebugInsight {
  id               String          @id @default(cuid())
  userProfileId    String
  codeRunId        String
  attemptId        String?
  interviewRoundId String?
  summary          String          @db.Text
  likelyCause      String          @db.Text
  suggestedFix     String          @db.Text
  followUpQuestion String?         @db.Text
  createdAt        DateTime        @default(now())
  userProfile      UserProfile     @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  codeRun          CodeRun         @relation(fields: [codeRunId], references: [id], onDelete: Cascade)
  attempt          Attempt?        @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  interviewRound   InterviewRound? @relation(fields: [interviewRoundId], references: [id], onDelete: SetNull)

  @@index([userProfileId])
  @@index([codeRunId])
  @@index([attemptId])
  @@index([interviewRoundId])
  @@index([createdAt])
}

model InterviewMessage {
  id                 String               @id @default(cuid())
  interviewSessionId String
  interviewRoundId   String?
  role               InterviewMessageRole
  content            String               @db.Text
  phase              InterviewPhase
  createdAt          DateTime             @default(now())
  interviewSession   InterviewSession     @relation(fields: [interviewSessionId], references: [id], onDelete: Cascade)
  interviewRound     InterviewRound?      @relation(fields: [interviewRoundId], references: [id], onDelete: Cascade)

  @@index([interviewSessionId])
  @@index([interviewRoundId])
  @@index([phase])
  @@index([createdAt])
}

model InterviewFeedback {
  id                      String           @id @default(cuid())
  interviewSessionId      String
  interviewRoundId        String?
  summary                 String           @db.Text
  strengths               String[]         @default([])
  weaknesses              String[]         @default([])
  rubric                  Json             @default("{}")
  followUpRecommendations String[]         @default([])
  createdAt               DateTime         @default(now())
  interviewSession        InterviewSession @relation(fields: [interviewSessionId], references: [id], onDelete: Cascade)
  interviewRound          InterviewRound?  @relation(fields: [interviewRoundId], references: [id], onDelete: Cascade)

  @@index([interviewSessionId])
  @@index([interviewRoundId])
  @@index([createdAt])
}

model InterviewRubricScore {
  id                 String           @id @default(cuid())
  interviewSessionId String
  category           RubricCategory
  score              Int
  notes              String           @db.Text
  createdAt          DateTime         @default(now())
  interviewSession   InterviewSession @relation(fields: [interviewSessionId], references: [id], onDelete: Cascade)

  @@index([interviewSessionId])
  @@index([category])
  @@index([createdAt])
}
